# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration - Choose ONE approach:

# APPROACH 1: Connection String (Recommended for Production with Pooler)
# Get this from Supabase Dashboard > Settings > Database > Connection String
# Select "Connection pooling" and "Transaction mode"
# DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&mode=transaction

# APPROACH 2: Individual Parameters (For Local Development)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=nic_portal
DB_PORT=5432
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173
